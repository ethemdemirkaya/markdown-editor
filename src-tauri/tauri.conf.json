{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Markdown Editor",
  "version": "0.2.0",
  "identifier": "com.ethemdemirkaya.markdowneditor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Markdown Editor",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd"],
        "name": "Markdown",
        "description": "Markdown document",
        "role": "Editor",
        "mimeType": "text/markdown"
      }
    ],
    "copyright": "© 2026 Ethem Demirkaya. MIT License.",
    "shortDescription": "Modern WYSIWYG markdown editor.",
    "longDescription": "Markdown Editor — Tauri 2.0 + Svelte tabanlı, WYSIWYG markdown düzenleyici. Live preview, KaTeX matematik, kod bloğu otomatik dil algılama, çoklu sekme, dosya I/O, HTML/PDF export, içindekiler paneli, bul/değiştir, ayarlanabilir @-block menü.",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/nsis-header.bmp",
        "sidebarImage": "icons/nsis-sidebar.bmp",
        "installMode": "currentUser",
        "displayLanguageSelector": true,
        "languages": ["English", "Turkish"],
        "compression": "lzma"
      },
      "wix": {
        "language": ["en-US"]
      }
    }
  }
}
